<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Discovery Agent Suite</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,500;9..144,700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg:         #09090f;
      --bg2:        #111118;
      --bg3:        #17171f;
      --bg4:        #1e1e28;
      --border:     #222230;
      --border2:    #2c2c3c;
      --text:       #c4c8d8;
      --dim:        #656878;
      --faint:      #32323f;
      --bright:     #eeeef6;
      --gold:       #e8b84b;
      --gold-bg:    rgba(232,184,75,.1);
      --green:      #46c98a;
      --green-bg:   rgba(70,201,138,.09);
      --red:        #e05252;
      --red-bg:     rgba(224,82,82,.09);
      --blue:       #5b9de0;
      --purple:     #9b86e0;
      --purple-bg:  rgba(155,134,224,.09);
      --serif:      'Fraunces', Georgia, serif;
      --mono:       'JetBrains Mono', 'Fira Code', monospace;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body { height: 100%; overflow: hidden; background: var(--bg); color: var(--text); font-family: var(--mono); font-size: 13px; line-height: 1.6; }

    /* ── Layout ── */
    #app {
      display: grid;
      height: 100vh;
      grid-template-rows: 44px 1fr auto;
      grid-template-columns: 252px 1fr;
      grid-template-areas: "hdr hdr" "side main" "logs logs";
    }

    /* ── Header ── */
    #hdr {
      grid-area: hdr;
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 0 20px;
      background: var(--bg2);
      border-bottom: 1px solid var(--border);
    }
    .hdr-logo {
      font-family: var(--serif);
      font-size: 13px;
      font-variation-settings: 'opsz' 14;
      font-weight: 500;
      color: var(--bright);
      letter-spacing: .05em;
      white-space: nowrap;
    }
    .hdr-logo b { color: var(--gold); font-weight: 500; }
    .hdr-sep { flex: 1; }
    #hdr-topic { font-size: 11px; color: var(--dim); max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    #hdr-tokens { font-size: 11px; color: var(--dim); white-space: nowrap; }
    #hdr-tokens span { color: var(--gold); }
    .hdr-btn {
      padding: 3px 10px;
      background: transparent;
      border: 1px solid var(--border2);
      color: var(--dim);
      font-family: var(--mono);
      font-size: 11px;
      cursor: pointer;
      border-radius: 2px;
      transition: border-color .15s, color .15s;
    }
    .hdr-btn:hover { border-color: var(--gold); color: var(--gold); }

    /* ── Sidebar ── */
    #side {
      grid-area: side;
      background: var(--bg2);
      border-right: 1px solid var(--border);
      overflow-y: auto;
      padding: 12px 0;
    }
    #side::-webkit-scrollbar { width: 3px; }
    #side::-webkit-scrollbar-thumb { background: var(--border2); }
    .side-lbl { font-size: 10px; letter-spacing: .14em; text-transform: uppercase; color: var(--faint); padding: 0 14px 8px; }

    .si {
      padding: 9px 14px;
      cursor: pointer;
      border-left: 2px solid transparent;
      transition: background .1s;
      user-select: none;
    }
    .si:hover { background: var(--bg3); }
    .si.s-act  { background: var(--bg3); border-left-color: var(--gold); }
    .si.s-pass { border-left-color: var(--green); }
    .si.s-fail { border-left-color: var(--red); }
    .si.s-over { border-left-color: var(--purple); }
    .si.s-pin  { background: var(--bg4); }

    .si-num { font-size: 10px; color: var(--faint); letter-spacing: .08em; margin-bottom: 1px; }
    .si-lbl {
      font-family: var(--serif);
      font-size: 13px;
      font-variation-settings: 'opsz' 14;
      font-weight: 500;
      color: var(--text);
      margin-bottom: 4px;
    }
    .si.s-act .si-lbl, .si.s-pass .si-lbl { color: var(--bright); }

    .badge { font-size: 10px; padding: 1px 5px; border-radius: 2px; }
    .b-pend { color: var(--faint);  background: var(--bg4); }
    .b-wait { color: var(--gold);   background: var(--gold-bg); }
    .b-think{ color: var(--gold);   background: var(--gold-bg); animation: pulse 1.2s infinite; }
    .b-pass { color: var(--green);  background: var(--green-bg); }
    .b-fail { color: var(--red);    background: var(--red-bg); }
    .b-over { color: var(--purple); background: var(--purple-bg); }

    .si-stats { display: flex; gap: 8px; margin-top: 4px; font-size: 10px; color: var(--dim); }

    /* ── Main ── */
    #main {
      grid-area: main;
      overflow-y: auto;
      padding: 26px 30px;
      display: flex;
      flex-direction: column;
      gap: 18px;
    }
    #main::-webkit-scrollbar { width: 4px; }
    #main::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

    /* Start screen */
    #start-screen {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100%;
      gap: 22px;
      text-align: center;
    }
    #start-screen h1 {
      font-family: var(--serif);
      font-size: 42px;
      font-variation-settings: 'opsz' 72;
      font-weight: 300;
      color: var(--bright);
      line-height: 1.1;
    }
    #start-screen h1 em { font-style: italic; color: var(--gold); }
    #start-screen p { font-size: 12px; color: var(--dim); max-width: 360px; line-height: 1.8; }

    /* Stage header */
    .sp-hdr { display: flex; align-items: baseline; gap: 12px; }
    .sp-hdr h2 {
      font-family: var(--serif);
      font-size: 22px;
      font-variation-settings: 'opsz' 36;
      font-weight: 500;
      color: var(--bright);
    }
    .sp-desc { font-size: 11px; color: var(--dim); margin-top: -10px; }

    /* Output block */
    .out-block { background: var(--bg2); border: 1px solid var(--border); border-radius: 4px; }
    .out-hdr {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 7px 14px;
      border-bottom: 1px solid var(--border);
    }
    .out-hdr-lbl { font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--dim); }
    .out-toks { font-size: 10px; color: var(--faint); }
    .out-body {
      padding: 14px;
      font-size: 12px;
      line-height: 1.78;
      white-space: pre-wrap;
      max-height: 400px;
      overflow-y: auto;
      color: var(--text);
    }
    .out-body::-webkit-scrollbar { width: 3px; }
    .out-body::-webkit-scrollbar-thumb { background: var(--border2); }
    .out-body.streaming::after { content: '▋'; display: inline-block; color: var(--gold); animation: pulse 0.8s infinite; margin-left: 1px; }

    /* Governance */
    .gov { border-radius: 4px; padding: 12px 14px; border: 1px solid var(--border); }
    .gov.gv-pass { border-color: rgba(70,201,138,.3); background: var(--green-bg); }
    .gov.gv-fail { border-color: rgba(224,82,82,.3);  background: var(--red-bg); }
    .gov.gv-over { border-color: rgba(155,134,224,.3); background: var(--purple-bg); }
    .gov.gv-run  { border-color: var(--border2); }
    .gov-row { display: flex; align-items: center; gap: 10px; margin-bottom: 5px; }
    .gov-status { font-size: 11px; font-weight: 500; }
    .gv-pass .gov-status { color: var(--green); }
    .gv-fail .gov-status { color: var(--red); }
    .gv-over .gov-status { color: var(--purple); }
    .gv-run  .gov-status { color: var(--dim); animation: pulse 1.2s infinite; }
    .gov-score { font-size: 11px; color: var(--dim); }
    .gov-verdict { font-size: 12px; color: var(--text); margin-bottom: 5px; }
    .gov-issues { list-style: none; font-size: 11px; color: var(--dim); }
    .gov-issues li::before { content: "• "; color: var(--red); }

    /* Condensed */
    .cond { background: var(--purple-bg); border: 1px solid rgba(155,134,224,.2); border-radius: 4px; padding: 12px 14px; }
    .cond-lbl { font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--purple); margin-bottom: 5px; }
    .cond-body { font-size: 11px; color: var(--dim); white-space: pre-wrap; line-height: 1.65; }

    /* Input block */
    .inp { background: var(--bg2); border: 1px solid var(--border2); border-radius: 4px; padding: 14px; }
    .inp label { display: block; font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--dim); margin-bottom: 8px; }
    .inp textarea, .inp input[type=text] {
      width: 100%;
      background: var(--bg3);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: var(--mono);
      font-size: 13px;
      padding: 10px;
      border-radius: 3px;
      resize: vertical;
      min-height: 88px;
      line-height: 1.6;
      transition: border-color .15s;
    }
    .inp input[type=text] { min-height: unset; }
    .inp textarea:focus, .inp input[type=text]:focus { outline: none; border-color: var(--gold); }
    .inp-row { display: flex; gap: 8px; margin-top: 10px; }

    /* Thinking */
    .think {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 4px;
      color: var(--gold);
      font-size: 12px;
    }
    .think-dots span {
      display: inline-block;
      width: 5px; height: 5px;
      background: var(--gold);
      border-radius: 50%;
      margin-right: 3px;
      animation: blink 1.4s infinite;
    }
    .think-dots span:nth-child(2) { animation-delay: .2s; }
    .think-dots span:nth-child(3) { animation-delay: .4s; }

    /* Override */
    .ovr { background: var(--red-bg); border: 1px solid rgba(224,82,82,.3); border-radius: 4px; padding: 16px; }
    .ovr h3 {
      font-family: var(--serif);
      font-size: 15px;
      font-variation-settings: 'opsz' 16;
      color: var(--red);
      margin-bottom: 6px;
    }
    .ovr p { font-size: 12px; color: var(--dim); margin-bottom: 12px; }

    /* Summary */
    .sum-tbl { width: 100%; border-collapse: collapse; font-size: 12px; }
    .sum-tbl th { text-align: left; padding: 6px 12px; font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: var(--faint); border-bottom: 1px solid var(--border); }
    .sum-tbl td { padding: 8px 12px; border-bottom: 1px solid var(--border); }
    .sum-tbl tr:last-child td { border-bottom: none; }

    /* Buttons */
    .btn-p {
      padding: 7px 18px;
      background: var(--gold);
      color: var(--bg);
      border: none;
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      border-radius: 3px;
      transition: opacity .15s;
    }
    .btn-p:hover { opacity: .85; }
    .btn-p:disabled { opacity: .35; cursor: not-allowed; }
    .btn-g {
      padding: 7px 18px;
      background: transparent;
      color: var(--dim);
      border: 1px solid var(--border2);
      font-family: var(--mono);
      font-size: 12px;
      cursor: pointer;
      border-radius: 3px;
      transition: border-color .15s, color .15s;
    }
    .btn-g:hover { border-color: var(--dim); color: var(--text); }
    .btn-d {
      padding: 7px 18px;
      background: transparent;
      color: var(--red);
      border: 1px solid rgba(224,82,82,.35);
      font-family: var(--mono);
      font-size: 12px;
      cursor: pointer;
      border-radius: 3px;
      transition: background .15s;
    }
    .btn-d:hover { background: rgba(224,82,82,.1); }

    /* ── Log strip ── */
    #logs {
      grid-area: logs;
      background: var(--bg2);
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      max-height: 180px;
      min-height: 32px;
      transition: max-height .2s ease;
    }
    #logs.closed { max-height: 32px; }
    #log-hdr {
      display: flex;
      align-items: center;
      padding: 0 14px;
      height: 32px;
      cursor: pointer;
      flex-shrink: 0;
      gap: 8px;
    }
    #log-hdr span { font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--faint); }
    #log-latest { flex: 1; font-size: 11px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin: 0 10px; }
    #log-tog { font-size: 10px; color: var(--faint); margin-left: auto; white-space: nowrap; }
    #log-body { flex: 1; overflow-y: auto; padding: 4px 14px 8px; }
    #logs.closed #log-body { display: none; }
    .ll { font-size: 11px; line-height: 1.8; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .l-info    { color: var(--dim); }
    .l-success { color: var(--green); }
    .l-warn    { color: var(--gold); }
    .l-error   { color: var(--red); }
    .l-muted   { color: var(--faint); }

    /* ── Context drawer ── */
    #ctx-mask {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.55);
      z-index: 50;
    }
    #ctx-mask.open { display: block; }
    #ctx-drawer {
      position: fixed;
      top: 0; right: 0; bottom: 0;
      width: 540px;
      background: var(--bg2);
      border-left: 1px solid var(--border2);
      display: flex;
      flex-direction: column;
      z-index: 51;
      transform: translateX(100%);
      transition: transform .24s ease;
    }
    #ctx-mask.open #ctx-drawer { transform: translateX(0); }
    .ctx-hdr { display: flex; align-items: center; padding: 0 18px; height: 50px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .ctx-hdr h3 { font-family: var(--serif); font-size: 15px; font-variation-settings: 'opsz' 16; font-weight: 500; color: var(--bright); flex: 1; }
    .ctx-close { background: none; border: none; color: var(--dim); cursor: pointer; font-size: 16px; padding: 4px; }
    .ctx-note { padding: 8px 18px; font-size: 11px; color: var(--faint); background: var(--bg3); border-bottom: 1px solid var(--border); flex-shrink: 0; line-height: 1.6; }
    #ctx-tabs { display: flex; overflow-x: auto; border-bottom: 1px solid var(--border); flex-shrink: 0; }
    #ctx-tabs::-webkit-scrollbar { height: 0; }
    .ctx-tab { padding: 8px 14px; font-size: 11px; color: var(--dim); cursor: pointer; white-space: nowrap; border-bottom: 2px solid transparent; transition: color .1s, border-color .1s; }
    .ctx-tab:hover { color: var(--text); }
    .ctx-tab.active { color: var(--gold); border-bottom-color: var(--gold); }
    #ctx-body { flex: 1; display: flex; flex-direction: column; padding: 14px 18px; gap: 10px; overflow: hidden; }
    #ctx-ta { flex: 1; background: var(--bg3); border: 1px solid var(--border); color: var(--text); font-family: var(--mono); font-size: 12px; padding: 12px; border-radius: 3px; resize: none; line-height: 1.7; transition: border-color .15s; }
    #ctx-ta:focus { outline: none; border-color: var(--gold); }
    #ctx-foot { display: flex; gap: 8px; align-items: center; }
    #ctx-status { font-size: 11px; color: var(--faint); margin-left: auto; }

    /* ── Animations ── */
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.45} }
    @keyframes blink { 0%,80%,100%{opacity:0} 40%{opacity:1} }
    @keyframes fu { from{opacity:0;transform:translateY(5px)} to{opacity:1;transform:translateY(0)} }
    .fu { animation: fu .2s ease forwards; }

    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }
  </style>
</head>
<body>
<div id="app">
  <header id="hdr">
    <div class="hdr-logo">DISCOVERY <b>AGENT</b> SUITE</div>
    <div class="hdr-sep"></div>
    <div id="hdr-topic"></div>
    <div id="hdr-tokens">tokens <span id="tok-count">0</span></div>
    <button class="hdr-btn" onclick="openCtx()">⌥ Context</button>
  </header>

  <aside id="side">
    <div class="side-lbl">Pipeline</div>
    <div id="stage-list"></div>
  </aside>

  <main id="main">
    <div id="start-screen">
      <h1>Discovery<br><em>Agent Suite</em></h1>
      <p style="margin-bottom:4px">Describe the problem. The pipeline runs end-to-end.</p>
      <p style="font-size:11px;color:var(--faint)">Problem → Opportunity → Stories → Estimation → Prioritisation</p>
      <div style="width:100%;max-width:560px;display:flex;flex-direction:column;gap:12px">
        <textarea id="start-topic" rows="6"
          placeholder="Describe the problem that needs solving — include context, who is affected, what's broken, and what success looks like. The more specific, the better the output."
          style="background:var(--bg2);border:1px solid var(--border2);color:var(--text);font-family:var(--mono);font-size:13px;padding:14px;border-radius:3px;outline:none;transition:border-color .15s;width:100%;resize:vertical;line-height:1.7"
          oninput="document.getElementById('btn-start').disabled=!this.value.trim()"
          onfocus="this.style.borderColor='var(--gold)'"
          onblur="this.style.borderColor='var(--border2)'"
        ></textarea>
        <button class="btn-p" id="btn-start" disabled onclick="startPipeline()" style="padding:11px 32px;font-size:13px;align-self:flex-start">▶ Run Pipeline</button>
      </div>
    </div>
    <div id="panel" style="display:none;flex-direction:column;gap:18px"></div>
  </main>

  <div id="logs" class="closed">
    <div id="log-hdr" onclick="toggleLogs()">
      <span>Log</span>
      <div id="log-latest" class="l-muted"></div>
      <span id="log-tog">▲ expand</span>
    </div>
    <div id="log-body"></div>
  </div>
</div>

<!-- Context drawer -->
<div id="ctx-mask" onclick="handleMask(event)">
  <div id="ctx-drawer">
    <div class="ctx-hdr">
      <h3>Project Context</h3>
      <button class="ctx-close" onclick="closeCtx()">✕</button>
    </div>
    <div class="ctx-note">Injected into each agent's system prompt. Changes apply to the next agent run — no restart needed.</div>
    <div id="ctx-tabs"></div>
    <div id="ctx-body">
      <textarea id="ctx-ta" placeholder="Loading…"></textarea>
      <div id="ctx-foot">
        <button class="btn-p" onclick="saveCtx()">Save</button>
        <button class="btn-g" onclick="closeCtx()">Close</button>
        <span id="ctx-status"></span>
      </div>
    </div>
  </div>
</div>

<script>
// ── State ──────────────────────────────────────────────────────────────────────
const S = {
  status: 'idle',   // idle | running | complete
  stages: [],
  sd: [],           // per-stage: { status, startTime, endTime, output, governance, condensed, runUsage, govUsage, score, passed }
  activeIdx: -1,
  input: null,      // { prompt, type }
  pinned: null,     // stage index being inspected
  tokIn: 0,
  tokOut: 0,
};

// ── Utils ──────────────────────────────────────────────────────────────────────
const esc = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const mk  = (t,c) => { const e=document.createElement(t); if(c)e.className=c; return e; };
const fms = ms => { if(!ms)return ''; return ms<1000 ? ms+'ms' : (ms/1000).toFixed(1)+'s'; };
const ftk = u => { if(!u)return ''; const t=(u.input_tokens||0)+(u.output_tokens||0); return t>999?(t/1000).toFixed(1)+'k':String(t); };

// ── Live timers ────────────────────────────────────────────────────────────────
const timers = {};
function startTimer(i) {
  if (timers[i]) return;
  timers[i] = setInterval(() => {
    const d = S.sd[i];
    if (!d || d.endTime) { clearInterval(timers[i]); delete timers[i]; return; }
    refreshSI(i);
  }, 500);
}
function stopTimer(i) { if (timers[i]) { clearInterval(timers[i]); delete timers[i]; } }

// ── SSE ────────────────────────────────────────────────────────────────────────
const sse = new EventSource('/events');

sse.addEventListener('pipeline-init', e => {
  const { stages } = JSON.parse(e.data);
  S.stages = stages;
  S.sd = stages.map(() => ({ status: 'pending' }));
  renderSidebar();
});

sse.addEventListener('agent-start', e => {
  const { index } = JSON.parse(e.data);
  S.activeIdx = index;
  S.sd[index] = { ...S.sd[index], status: 'waiting', startTime: Date.now() };
  startTimer(index);
  refreshSI(index);
  if (S.pinned === null) renderPanel();
});

sse.addEventListener('agent-thinking', e => {
  const { index } = JSON.parse(e.data);
  S.sd[index].status = 'thinking';
  refreshSI(index);
  if (S.pinned === null) renderPanel();
});

sse.addEventListener('agent-chunk', e => {
  const { index, chunk } = JSON.parse(e.data);
  const d = S.sd[index];
  if (!d.output) d.output = '';
  d.output += chunk;
  // Direct DOM update — no full re-render per chunk
  const body = document.getElementById(`out-body-${index}`);
  if (body) {
    body.textContent = d.output;
    body.scrollTop = body.scrollHeight;
  } else if (S.pinned === null) {
    // First chunk: render the panel to create the output block
    renderPanel();
  }
});

sse.addEventListener('agent-output', e => {
  const { index, output, runUsage } = JSON.parse(e.data);
  S.sd[index].output = output;
  S.sd[index].runUsage = runUsage;
  if (runUsage) { S.tokIn += runUsage.input_tokens || 0; S.tokOut += runUsage.output_tokens || 0; updateTok(); }
  // Update token display in-place if the block exists; remove streaming cursor
  const body = document.getElementById(`out-body-${index}`);
  const toks = document.getElementById(`out-toks-${index}`);
  if (body) {
    body.classList.remove('streaming');
    if (toks && runUsage) toks.textContent = `↑${runUsage.input_tokens || 0} ↓${runUsage.output_tokens || 0}`;
  } else if (S.pinned === null) {
    renderPanel();
  }
});

sse.addEventListener('governance', e => {
  const { index, ...gov } = JSON.parse(e.data);
  S.sd[index].governance = gov;
  if (S.pinned === null) renderPanel();
});

sse.addEventListener('agent-condensed', e => {
  const { index, condensed } = JSON.parse(e.data);
  S.sd[index].condensed = condensed;
  if (S.pinned === null || S.pinned === index) renderPanel();
});

sse.addEventListener('agent-complete', e => {
  const { index, score, passed, override, govUsage } = JSON.parse(e.data);
  const d = S.sd[index];
  d.score = score; d.passed = passed; d.endTime = Date.now(); d.govUsage = govUsage;
  d.status = override ? 'override' : (passed ? 'passed' : 'failed');
  if (govUsage) { S.tokIn += govUsage.input_tokens || 0; S.tokOut += govUsage.output_tokens || 0; updateTok(); }
  stopTimer(index);
  refreshSI(index);
  if (S.pinned === null) renderPanel();
});

sse.addEventListener('input-request', e => {
  const { prompt, type } = JSON.parse(e.data);

  // Auto-submit session slug (used for filename, not shown to agents)
  if (type === 'topic') {
    fetch('/input', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ value: pendingTopic }) });
    pendingTopic = '';
    return;
  }

  if (type === 'agent') {
    const idx  = S.activeIdx;
    const d    = idx >= 0 ? S.sd[idx] : null;
    const isRetry = d?.governance != null; // governance exists = previous attempt failed governance

    if (!isRetry) {
      if (idx === 0 && pendingProblem) {
        // Problem Framing — auto-submit the problem statement entered on the start screen
        const val = pendingProblem;
        pendingProblem = '';
        S.sd[idx].status = 'thinking';
        refreshSI(idx);
        fetch('/input', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ value: val }) });
        if (S.pinned === null) renderPanel();
        return;
      }
      if (idx > 0) {
        // Show review step — user confirms previous output before next agent runs
        S.input = { prompt, type, review: true };
        S.sd[idx].status = 'waiting';
        refreshSI(idx);
        if (S.pinned === null) renderPanel();
        return;
      }
    }

    // Retry after governance failure — show input form so user can add context
    S.input = { prompt, type };
    S.sd[idx].status = 'waiting';
    refreshSI(idx);
    renderPanel();
    return;
  }

  // Fallback
  S.input = { prompt, type };
  renderPanel();
});

sse.addEventListener('override-request', e => {
  const { index } = JSON.parse(e.data);
  S.sd[index].status = 'override-req';
  S.input = { prompt: '', type: 'override' };
  refreshSI(index);
  if (S.pinned === null) renderPanel();
});

sse.addEventListener('pipeline-complete', e => {
  const { aborted } = JSON.parse(e.data);
  S.status = 'complete'; S.aborted = aborted; S.input = null;
  renderSidebar(); renderPanel();
});

sse.addEventListener('log', e => {
  const { level, text } = JSON.parse(e.data);
  appendLog(level, text);
});

// ── Sidebar ────────────────────────────────────────────────────────────────────
function renderSidebar() {
  const list = document.getElementById('stage-list');
  list.innerHTML = '';
  S.stages.forEach((_, i) => {
    const el = mk('div');
    el.id = `si-${i}`;
    el.onclick = () => pin(i);
    list.appendChild(el);
    refreshSI(i);
  });
}

function refreshSI(i) {
  const el = document.getElementById(`si-${i}`);
  if (!el) return;
  const s = S.stages[i];
  const d = S.sd[i] || { status: 'pending' };
  const elapsed = d.startTime ? (d.endTime || Date.now()) - d.startTime : 0;

  const stCls = { pending:'', waiting:'s-act', thinking:'s-act', passed:'s-pass', failed:'s-fail', override:'s-over', 'override-req':'s-act' }[d.status] || '';
  el.className = `si ${stCls} ${S.pinned === i ? 's-pin' : ''}`;

  const [bc, bt] = {
    pending:       ['b-pend', 'pending'],
    waiting:       ['b-wait', 'input'],
    thinking:      ['b-think','thinking…'],
    passed:        ['b-pass', d.score != null ? `${d.score}/100` : 'passed'],
    failed:        ['b-fail', d.score != null ? `${d.score}/100` : 'failed'],
    override:      ['b-over', 'override'],
    'override-req':['b-wait', 'override?'],
  }[d.status] || ['b-pend','—'];

  const toks = [ftk(d.runUsage), ftk(d.govUsage)].filter(Boolean).join('+');

  el.innerHTML = `
    <div class="si-num">0${i + 1}</div>
    <div class="si-lbl">${esc(s.label)}</div>
    <div><span class="badge ${bc}">${bt}</span></div>
    ${elapsed || toks ? `<div class="si-stats">${elapsed ? `<span>${fms(elapsed)}</span>` : ''}${toks ? `<span>${toks} tok</span>` : ''}</div>` : ''}
  `;
}

// ── Panel ──────────────────────────────────────────────────────────────────────
function renderPanel() {
  const startEl = document.getElementById('start-screen');
  const panel   = document.getElementById('panel');

  if (S.status === 'idle') { startEl.style.display = 'flex'; panel.style.display = 'none'; return; }
  startEl.style.display = 'none';
  panel.style.display = 'flex';
  panel.innerHTML = '';

  if (S.status === 'complete') { renderComplete(panel); return; }
  if (S.pinned !== null)       { renderPinned(panel, S.pinned); return; }

  const idx = S.activeIdx;
  if (idx < 0) {
    if (S.input?.type === 'topic') renderTopicInput(panel);
    return;
  }

  const d  = S.sd[idx];
  const ag = S.stages[idx];

  panel.appendChild(hdrEl(ag.label));
  panel.appendChild(descEl(ag.description));

  // Output (always show latest if available)
  if (d.output) panel.appendChild(buildOutput(d.output, d.runUsage, idx));

  // Governance: running indicator or result
  if (d.output && !d.governance && d.status === 'thinking') {
    const g = mk('div', 'gov gv-run fu');
    g.innerHTML = `<div class="gov-row"><span class="gov-status">Checking quality…</span></div>`;
    panel.appendChild(g);
  }
  if (d.governance) panel.appendChild(buildGov(d.governance, d.status));

  // Condensed (stage done)
  if (d.condensed && (d.status === 'passed' || d.status === 'override')) panel.appendChild(buildCond(d.condensed));

  // Override choice
  if (d.status === 'override-req') panel.appendChild(buildOverride(ag));

  // Input form (retry) or review-and-continue step
  if (d.status === 'waiting' && S.input) {
    if (S.input.review) panel.appendChild(buildContinueReview(idx));
    else panel.appendChild(buildInp(S.input, idx, !!d.output));
  }

  // Thinking with no output yet
  if (d.status === 'thinking' && !d.output) {
    const t = mk('div', 'think fu');
    t.innerHTML = `<div class="think-dots"><span></span><span></span><span></span></div><span>Generating…</span>`;
    panel.appendChild(t);
  }
}

function renderTopicInput(panel) {
  panel.appendChild(hdrEl('New Session'));
  const id = 'topic-inp';
  const b = mk('div', 'inp fu');
  b.innerHTML = `
    <label>Session Topic</label>
    <input type="text" id="${id}" placeholder="e.g. payment-flow-redesign" />
    <div class="inp-row"><button class="btn-p" onclick="doSubmit('${id}')">Begin →</button></div>`;
  panel.appendChild(b);
  setTimeout(() => document.getElementById(id)?.focus(), 50);
}

function renderPinned(panel, i) {
  const d = S.sd[i], ag = S.stages[i];
  const hdr = mk('div', 'sp-hdr fu');
  hdr.innerHTML = `<h2>${esc(ag.label)}</h2><button class="btn-g" style="margin-left:auto;font-size:11px" onclick="unpin()">← Back</button>`;
  panel.appendChild(hdr);
  panel.appendChild(descEl(ag.description));
  if (d.output) panel.appendChild(buildOutput(d.output, d.runUsage, i));
  if (d.governance) panel.appendChild(buildGov(d.governance, d.status));
  if (d.condensed) panel.appendChild(buildCond(d.condensed));
}

function renderComplete(panel) {
  const c = mk('div', 'fu');
  const rows = S.stages.map((ag, i) => {
    const d = S.sd[i] || {};
    if (d.status === 'pending') return '';
    const elapsed = d.startTime && d.endTime ? fms(d.endTime - d.startTime) : '—';
    const tok = [ftk(d.runUsage), ftk(d.govUsage)].filter(Boolean).join('+') || '—';
    const res = d.status === 'passed'   ? `<span style="color:var(--green)">✓ ${d.score}/100</span>`
              : d.status === 'override' ? `<span style="color:var(--purple)">⚠ override</span>`
              : `<span style="color:var(--red)">✗ ${d.score || 0}/100</span>`;
    return `<tr><td>${esc(ag.label)}</td><td>${res}</td><td>${elapsed}</td><td>${tok}</td></tr>`;
  }).join('');

  const total = S.tokIn + S.tokOut;
  c.innerHTML = `
    <h2 style="font-family:var(--serif);font-size:24px;font-variation-settings:'opsz' 36;font-weight:500;color:var(--${S.aborted ? 'red' : 'green'});margin-bottom:18px">
      ${S.aborted ? 'Session Ended' : 'Pipeline Complete'}
    </h2>
    <table class="sum-tbl">
      <thead><tr><th>Stage</th><th>Result</th><th>Time</th><th>Tokens</th></tr></thead>
      <tbody>${rows}</tbody>
    </table>
    <div style="margin-top:18px;display:flex;align-items:center;gap:16px">
      <button class="btn-p" onclick="startPipeline()">▶ New Session</button>
      <span style="font-size:11px;color:var(--dim)">${total > 999 ? (total / 1000).toFixed(1) + 'k' : total} tokens total</span>
    </div>`;
  panel.appendChild(c);
}

// ── Block builders ─────────────────────────────────────────────────────────────
function hdrEl(label) {
  const h = mk('div', 'sp-hdr fu');
  h.innerHTML = `<h2>${esc(label)}</h2>`;
  return h;
}
function descEl(desc) {
  const d = mk('div', 'sp-desc');
  d.textContent = desc;
  return d;
}
function buildOutput(output, runUsage, idx) {
  const b = mk('div', 'out-block fu');
  const tok = runUsage ? `↑${runUsage.input_tokens || 0} ↓${runUsage.output_tokens || 0}` : '';
  const idAttr = idx != null ? ` id="out-body-${idx}"` : '';
  const tokId  = idx != null ? ` id="out-toks-${idx}"` : '';
  // Mark as streaming if no runUsage yet (output is still coming in)
  const streamCls = (!runUsage && output) ? ' streaming' : '';
  b.innerHTML = `
    <div class="out-hdr"><span class="out-hdr-lbl">Output</span><span class="out-toks"${tokId}>${tok}</span></div>
    <div class="out-body${streamCls}"${idAttr}>${esc(output)}</div>`;
  return b;
}
function buildGov(gov, status) {
  const cls = status === 'override' ? 'gv-over' : gov.passed ? 'gv-pass' : 'gv-fail';
  const lbl = status === 'override' ? '⚠ Override' : gov.passed ? '✓ Governance Passed' : '✗ Governance Failed';
  const b = mk('div', `gov ${cls} fu`);
  const issues = gov.issues?.length ? `<ul class="gov-issues">${gov.issues.map(x => `<li>${esc(x)}</li>`).join('')}</ul>` : '';
  const gtok = gov.usage ? `<span class="gov-score">${ftk(gov.usage)} tok</span>` : '';
  b.innerHTML = `
    <div class="gov-row">
      <span class="gov-status">${lbl}</span>
      <span class="gov-score">${gov.score}/100</span>${gtok}
    </div>
    ${gov.verdict ? `<div class="gov-verdict">${esc(gov.verdict)}</div>` : ''}
    ${issues}`;
  return b;
}
function buildCond(condensed) {
  const b = mk('div', 'cond fu');
  b.innerHTML = `<div class="cond-lbl">→ Passed to next stage</div><div class="cond-body">${esc(condensed)}</div>`;
  return b;
}
function buildInp(pending, idx, isRetry) {
  const id = `inp-${idx}-${Date.now()}`;
  const lbl = isRetry ? 'Add context for retry — or leave blank to retry with governance feedback only' : (pending.prompt || 'Your input');
  const b = mk('div', 'inp fu');
  b.innerHTML = `
    <label>${esc(lbl)}</label>
    <textarea id="${id}" rows="4" placeholder="${isRetry ? 'Optional: add more context…' : 'Your input…'}"></textarea>
    <div class="inp-row">
      <button class="btn-p" onclick="doSubmit('${id}')">Submit →</button>
      ${isRetry ? `<button class="btn-g" onclick="doSubmit('${id}',true)">Skip (retry with feedback)</button>` : ''}
    </div>`;
  setTimeout(() => document.getElementById(id)?.focus(), 50);
  return b;
}
function buildOverride(ag) {
  const b = mk('div', 'ovr fu');
  b.innerHTML = `
    <h3>Max attempts reached</h3>
    <p>The output for <strong>${esc(ag.label)}</strong> could not pass governance after the maximum number of attempts.</p>
    <div class="inp-row">
      <button class="btn-p" onclick="sendOverride('override')">Override — accept and continue</button>
      <button class="btn-d" onclick="sendOverride('quit')">Quit session</button>
    </div>`;
  return b;
}

function buildContinueReview(idx) {
  const prevIdx = idx - 1;
  const prevAg  = S.stages[prevIdx] || {};
  const prevD   = S.sd[prevIdx]     || {};
  const nextAg  = S.stages[idx]     || {};
  const b = mk('div', 'fu');
  if (prevD.condensed) {
    const cond = mk('div', 'cond');
    cond.innerHTML = `<div class="cond-lbl">${esc(prevAg.label)} — summary passed to next stage</div><div class="cond-body">${esc(prevD.condensed)}</div>`;
    b.appendChild(cond);
  }
  const row = mk('div', 'inp');
  row.style.marginTop = '12px';
  row.innerHTML = `
    <label>Review complete — ready to continue?</label>
    <div class="inp-row"><button class="btn-p" onclick="continueToNext()">▶ Run ${esc(nextAg.label || 'next stage')}</button></div>`;
  b.appendChild(row);
  return b;
}

// ── Actions ────────────────────────────────────────────────────────────────────
let pendingTopic = '';
let pendingProblem = '';

function toSlug(text) {
  return text.toLowerCase().replace(/[^a-z0-9\s]/g, '').trim().split(/\s+/).slice(0, 6).join('-');
}

async function startPipeline() {
  const topicEl = document.getElementById('start-topic');
  const problem = topicEl?.value.trim() || '';
  if (!problem) return;

  pendingProblem = problem;
  pendingTopic   = toSlug(problem);

  const btn = document.getElementById('btn-start');
  if (btn) btn.disabled = true;
  Object.assign(S, { status: 'running', activeIdx: -1, pinned: null, input: null, tokIn: 0, tokOut: 0, stages: [], sd: [] });
  document.getElementById('hdr-topic').textContent = pendingTopic;
  document.getElementById('tok-count').textContent = '0';
  document.getElementById('log-body').innerHTML = '';
  renderPanel();

  let res = await fetch('/start', { method: 'POST' });
  if (res.status === 409) {
    // Stale pipeline — reset silently and retry once
    appendLog('warn', 'Resetting stale pipeline…');
    await fetch('/reset', { method: 'POST' });
    res = await fetch('/start', { method: 'POST' });
  }
  if (!res.ok) {
    const err = await res.json();
    appendLog('error', err.error || 'Failed to start');
    S.status = 'idle'; pendingTopic = ''; pendingProblem = ''; renderPanel();
    if (btn) btn.disabled = false;
  }
}

function continueToNext() {
  S.input = null;
  const idx = S.activeIdx;
  if (idx >= 0) { S.sd[idx].status = 'thinking'; refreshSI(idx); }
  fetch('/input', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ value: '' }) });
  renderPanel();
}

function doSubmit(id, blank = false) {
  const el = document.getElementById(id);
  const value = blank ? '' : (el?.value || '');
  S.input = null;
  if (S.activeIdx < 0 && value) {
    document.getElementById('hdr-topic').textContent = value;
  }
  fetch('/input', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ value }) });
  if (S.activeIdx >= 0) { S.sd[S.activeIdx].status = 'thinking'; refreshSI(S.activeIdx); }
  renderPanel();
}

function sendOverride(choice) {
  S.input = null;
  fetch('/input', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ value: choice }) });
}

function pin(i) {
  if (!S.sd[i]?.output) return;
  S.pinned = i;
  document.querySelectorAll('.si').forEach((el, idx) => el.classList.toggle('s-pin', idx === i));
  renderPanel();
}

function unpin() {
  S.pinned = null;
  document.querySelectorAll('.si').forEach(el => el.classList.remove('s-pin'));
  renderPanel();
}

function updateTok() {
  const t = S.tokIn + S.tokOut;
  document.getElementById('tok-count').textContent = t > 999 ? (t / 1000).toFixed(1) + 'k' : t;
}

// ── Logs ────────────────────────────────────────────────────────────────────────
function appendLog(level, text) {
  const body = document.getElementById('log-body');
  const line = mk('div', `ll l-${level}`);
  line.textContent = text;
  body.appendChild(line);
  body.scrollTop = body.scrollHeight;
  const latest = document.getElementById('log-latest');
  latest.textContent = text;
  latest.className = `l-${level}`;
}

let logsOpen = false;
function toggleLogs() {
  logsOpen = !logsOpen;
  document.getElementById('logs').classList.toggle('closed', !logsOpen);
  document.getElementById('log-tog').textContent = logsOpen ? '▼ collapse' : '▲ expand';
}

// ── Context editor ──────────────────────────────────────────────────────────────
let ctxFiles = {}, ctxActive = null;

async function openCtx() {
  document.getElementById('ctx-mask').classList.add('open');
  document.getElementById('ctx-status').textContent = 'Loading…';
  const res = await fetch('/context');
  ctxFiles = await res.json();
  const tabs = document.getElementById('ctx-tabs');
  tabs.innerHTML = '';
  const keys = Object.keys(ctxFiles).sort((a, b) => a === 'shared.md' ? -1 : b === 'shared.md' ? 1 : a.localeCompare(b));
  keys.forEach(f => {
    const t = mk('div', 'ctx-tab');
    t.id = `ct-${f}`;
    t.textContent = f.replace('.md', '');
    t.onclick = () => switchCtx(f);
    tabs.appendChild(t);
  });
  document.getElementById('ctx-status').textContent = '';
  switchCtx(keys[0]);
}

function switchCtx(file) {
  ctxActive = file;
  document.querySelectorAll('.ctx-tab').forEach(t => t.classList.remove('active'));
  document.getElementById(`ct-${file}`)?.classList.add('active');
  document.getElementById('ctx-ta').value = ctxFiles[file] || '';
}

async function saveCtx() {
  if (!ctxActive) return;
  const content = document.getElementById('ctx-ta').value;
  const st = document.getElementById('ctx-status');
  st.textContent = 'Saving…'; st.style.color = '';
  ctxFiles[ctxActive] = content;
  const res = await fetch(`/context/${encodeURIComponent(ctxActive)}`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ content })
  });
  if (res.ok) { st.textContent = '✓ Saved'; setTimeout(() => { st.textContent = ''; }, 2000); }
  else { st.style.color = 'var(--red)'; st.textContent = '✗ Error'; }
}

function closeCtx() { document.getElementById('ctx-mask').classList.remove('open'); }
function handleMask(e) { if (e.target === document.getElementById('ctx-mask')) closeCtx(); }

// Enter to submit single-line inputs
document.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey && document.activeElement?.tagName === 'INPUT' && document.activeElement.type === 'text') {
    e.preventDefault();
    document.activeElement.closest('.inp')?.querySelector('.btn-p')?.click();
  }
});
</script>
</body>
</html>
