# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Pipeline tuning ───────────────────────────────────────────────────────────
# Maximum governance retry attempts per stage (default: 3)
MAX_ATTEMPTS=3

# Comma-separated stage IDs to run — leave blank to run all five stages
# Valid IDs: problem-framing, opportunity-framing, story-creation, estimation, prioritisation
PIPELINE_STAGES=

# Set to 1 to automatically accept stages that fail governance (no manual override prompt)
AUTO_OVERRIDE=0

# Set to 1 to skip output condensation — faster runs, less context carried forward
DISABLE_CONDENSE=0

# ── Token limits (override per-agent defaults) ────────────────────────────────
# Raise these if outputs are being truncated
AGENT_MAX_TOKENS=
GOVERNANCE_MAX_TOKENS=
CONDENSE_MAX_TOKENS=
FINAL_GOVERNANCE_MAX_TOKENS=

# ── Jira / Track & Release integration ────────────────────────────────────────
# Jira instance name (segment of your T&R URL: rb-tracker.bosch.com/<instance>/)
TR_INSTANCE=tracker19
# Personal Access Token — create at rb-tracker.bosch.com/<instance> → Profile → Personal Access Tokens
TR_PAT=
# Bosch API Gateway key — subscribe to "Copilot Studio - Track & Release API" in the API Marketplace
TR_API_KEY=
# Jira project key stories are pushed into (default: BGAPA)
JIRA_PROJECT_KEY=BGAPA

# ── Proxy (optional) ──────────────────────────────────────────────────────────
# Bosch VPN example: HTTPS_PROXY=http://localhost:3128
HTTPS_PROXY=
